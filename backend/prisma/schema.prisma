generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  user

  @@map("user_role")
}

enum TokenType {
  refresh
  resetPassword
  verifyEmail

  @@map("token_type")
}

enum StoreRole {
  owner
  manager
  staff

  @@map("store_role")
}

enum ReceiptStatus {
  draft
  completed
  cancelled

  @@map("receipt_status")
}

enum SaleStatus {
  completed
  cancelled
  refunded

  @@map("sale_status")
}

enum PaymentMethod {
  cash
  bank_transfer
  card
  e_wallet
  other

  @@map("payment_method")
}

enum InventoryMovementType {
  import
  sale
  return
  adjustment
  damage
  expired
  transfer_in
  transfer_out

  @@map("inventory_movement_type")
}

enum InventoryReferenceType {
  import_receipt
  sale
  manual_adjustment
  stock_transfer

  @@map("inventory_reference_type")
}

model User {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String              @map("full_name") @db.VarChar(255)
  phone              String?             @unique @db.VarChar(20)
  email              String              @unique @db.VarChar(255)
  password           String              @map("password_hash") @db.VarChar(255)
  role               Role                @default(user)
  isSystemAdmin      Boolean             @default(false) @map("is_system_admin")
  isEmailVerified    Boolean             @default(false) @map("is_email_verified")
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  tokens             Token[]
  storeRoles         UserStoreRole[]
  importReceipts     ImportReceipt[]     @relation("ImportCreatedBy")
  inventoryMovements InventoryMovement[] @relation("MovementCreatedBy")
  sales              Sale[]              @relation("SaleSoldBy")

  @@map("users")
}

model Token {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token       String
  userId      String    @map("user_id") @db.Uuid
  type        TokenType
  expires     DateTime  @db.Timestamptz(3)
  blacklisted Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([token, type, userId, blacklisted])
  @@map("tokens")
}

model Store {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String               @db.VarChar(255)
  address              String?
  phone                String?              @db.VarChar(20)
  isActive             Boolean              @default(true) @map("is_active")
  createdAt            DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  roles                UserStoreRole[]
  medicines            StoreMedicine[]
  importReceipts       ImportReceipt[]
  inventoryMovements   InventoryMovement[]
  stockBatches         StockBatch[]
  sales                Sale[]
  dailyProfitSummaries DailyProfitSummary[]
  importDetails        ImportDetail[]

  @@map("stores")
}

model UserStoreRole {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  storeId   String    @map("store_id") @db.Uuid
  role      StoreRole
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, storeId, role])
  @@index([userId])
  @@index([storeId])
  @@map("user_store_roles")
}

model Medicine {
  id                   String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String              @db.VarChar(255)
  baseUnitName         String              @map("base_unit_name") @db.VarChar(50)
  barcode              String?             @unique @db.VarChar(100)
  registrationNumber   String?             @unique @map("registration_number") @db.VarChar(100)
  category             String?             @db.VarChar(100)
  activeIngredient     String?             @map("active_ingredient") @db.VarChar(255)
  strength             String?             @db.VarChar(100)
  dosageForm           String?             @map("dosage_form") @db.VarChar(100)
  manufacturer         String?             @db.VarChar(255)
  requiresPrescription Boolean             @default(false) @map("requires_prescription")
  description          String?
  isActive             Boolean             @default(true) @map("is_active")
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  importDetails        ImportDetail[]
  inventoryMovements   InventoryMovement[]
  saleDetails          SaleDetail[]
  stockBatches         StockBatch[]
  storeMedicines       StoreMedicine[]

  @@index([name])
  @@index([barcode])
  @@map("medicines")
}

model StoreMedicine {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId      String   @map("store_id") @db.Uuid
  medicineId   String   @map("medicine_id") @db.Uuid
  sellingPrice Decimal  @default(0) @map("selling_price") @db.Decimal(14, 2)
  minStock     Decimal  @default(0) @map("min_stock") @db.Decimal(12, 2)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  medicine     Medicine @relation(fields: [medicineId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([storeId, medicineId])
  @@index([medicineId])
  @@map("store_medicines")
}

model Supplier {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String?         @unique @db.VarChar(50)
  name           String          @db.VarChar(255)
  phone          String?         @db.VarChar(20)
  email          String?         @db.VarChar(255)
  address        String?
  taxCode        String?         @map("tax_code") @db.VarChar(50)
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  importReceipts ImportReceipt[]

  @@index([name])
  @@map("suppliers")
}

model ImportReceipt {
  id                   String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId              String         @map("store_id") @db.Uuid
  createdBy            String         @map("created_by") @db.Uuid
  supplierId           String?        @map("supplier_id") @db.Uuid
  supplierNameSnapshot String?        @map("supplier_name_snapshot") @db.VarChar(255)
  status               ReceiptStatus  @default(completed)
  totalAmount          Decimal        @default(0) @map("total_amount") @db.Decimal(14, 2)
  note                 String?
  importedAt           DateTime       @default(now()) @map("imported_at") @db.Timestamptz(3)
  createdAt            DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  store                Store          @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdByUser        User           @relation("ImportCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Cascade)
  supplier             Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  details              ImportDetail[]

  @@index([storeId, importedAt])
  @@index([createdBy])
  @@index([supplierId])
  @@map("import_receipts")
}

model ImportDetail {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  importReceiptId String        @map("import_receipt_id") @db.Uuid
  storeId         String        @map("store_id") @db.Uuid
  medicineId      String        @map("medicine_id") @db.Uuid
  batchNumber     String        @map("batch_number") @db.VarChar(100)
  quantity        Decimal       @db.Decimal(12, 2)
  importPrice     Decimal       @map("import_price") @db.Decimal(14, 2)
  expiryDate      DateTime      @map("expiry_date") @db.Date
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  receipt         ImportReceipt @relation(fields: [importReceiptId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  store           Store         @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  medicine        Medicine      @relation(fields: [medicineId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  stockBatches    StockBatch[]

  @@index([importReceiptId])
  @@index([medicineId])
  @@index([storeId, medicineId, expiryDate])
  @@map("import_details")
}

model StockBatch {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId            String              @map("store_id") @db.Uuid
  medicineId         String              @map("medicine_id") @db.Uuid
  importDetailId     String?             @map("import_detail_id") @db.Uuid
  batchNumber        String              @map("batch_number") @db.VarChar(100)
  importPrice        Decimal             @map("import_price") @db.Decimal(14, 2)
  expiryDate         DateTime            @map("expiry_date") @db.Date
  quantityRemaining  Decimal             @map("quantity_remaining") @db.Decimal(12, 2)
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  store              Store               @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  medicine           Medicine            @relation(fields: [medicineId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  importDetail       ImportDetail?       @relation(fields: [importDetailId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  inventoryMovements InventoryMovement[]
  saleDetails        SaleDetail[]

  @@unique([id, storeId, medicineId])
  @@index([storeId, medicineId])
  @@index([storeId, medicineId, expiryDate])
  @@index([expiryDate])
  @@map("stock_batches")
}

model InventoryMovement {
  id            String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId       String                  @map("store_id") @db.Uuid
  medicineId    String                  @map("medicine_id") @db.Uuid
  stockBatchId  String?                 @map("stock_batch_id") @db.Uuid
  type          InventoryMovementType
  quantityDelta Decimal                 @map("quantity_delta") @db.Decimal(12, 2)
  referenceType InventoryReferenceType? @map("reference_type")
  referenceId   String?                 @map("reference_id") @db.Uuid
  note          String?
  createdBy     String?                 @map("created_by") @db.Uuid
  createdAt     DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)
  store         Store                   @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  medicine      Medicine                @relation(fields: [medicineId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  stockBatch    StockBatch?             @relation(fields: [stockBatchId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdByUser User?                   @relation("MovementCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([storeId, medicineId, createdAt])
  @@index([stockBatchId])
  @@index([referenceType, referenceId])
  @@map("inventory_movements")
}

model Sale {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId        String        @map("store_id") @db.Uuid
  soldBy         String        @map("sold_by") @db.Uuid
  status         SaleStatus    @default(completed)
  paymentMethod  PaymentMethod @default(cash) @map("payment_method")
  discountAmount Decimal       @default(0) @map("discount_amount") @db.Decimal(14, 2)
  totalAmount    Decimal       @default(0) @map("total_amount") @db.Decimal(14, 2)
  soldAt         DateTime      @default(now()) @map("sold_at") @db.Timestamptz(3)
  note           String?
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  store          Store         @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  soldByUser     User          @relation("SaleSoldBy", fields: [soldBy], references: [id], onDelete: Restrict, onUpdate: Cascade)
  details        SaleDetail[]

  @@unique([id, storeId])
  @@index([storeId, soldAt])
  @@index([soldBy])
  @@map("sales")
}

model SaleDetail {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  saleId       String     @map("sale_id") @db.Uuid
  storeId      String     @map("store_id") @db.Uuid
  medicineId   String     @map("medicine_id") @db.Uuid
  stockBatchId String     @map("stock_batch_id") @db.Uuid
  quantity     Decimal    @db.Decimal(12, 2)
  salePrice    Decimal    @map("sale_price") @db.Decimal(14, 2)
  costPrice    Decimal    @map("cost_price") @db.Decimal(14, 2)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  sale         Sale       @relation(fields: [saleId, storeId], references: [id, storeId], onDelete: Cascade, onUpdate: Cascade)
  medicine     Medicine   @relation(fields: [medicineId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  stockBatch   StockBatch @relation(fields: [stockBatchId, storeId, medicineId], references: [id, storeId, medicineId], onDelete: Restrict, onUpdate: Cascade)

  @@index([saleId])
  @@index([medicineId])
  @@index([stockBatchId])
  @@map("sale_details")
}

model DailyProfitSummary {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId      String   @map("store_id") @db.Uuid
  summaryDate  DateTime @map("summary_date") @db.Date
  totalRevenue Decimal  @default(0) @map("total_revenue") @db.Decimal(14, 2)
  totalCost    Decimal  @default(0) @map("total_cost") @db.Decimal(14, 2)
  totalProfit  Decimal  @default(0) @map("total_profit") @db.Decimal(14, 2)
  totalOrders  Int      @default(0) @map("total_orders")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([storeId, summaryDate])
  @@index([storeId, summaryDate])
  @@map("daily_profit_summary")
}
